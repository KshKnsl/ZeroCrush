generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  OPERATOR
  VIEWER
}

model User {
  id        Int      @id @default(autoincrement())
  name      String?
  email     String   @unique
  password  String
  role      Role     @default(VIEWER)
  createdAt DateTime @default(now())
}

model Session {
  id                  String   @id @default(uuid())
  source              String
  startTime           DateTime
  endTime             DateTime
  videoFps            Float
  processedFrameSize  Int
  trackMaxAge         Int
  tracksImageBase64   String?
  heatmapImageBase64  String?
  previewImageBase64  String?
  crowdPeakBase64     String?
  violationPeakBase64 String?
  crowdData           Json?
  energyBuckets       Json?
  logEvents           Json?
  createdAt           DateTime @default(now())
}
