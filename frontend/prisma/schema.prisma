generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  OPERATOR
  VIEWER
}

model User {
  id        Int        @id @default(autoincrement())
  name      String?
  email     String     @unique
  password  String
  role      Role       @default(VIEWER)
  createdAt DateTime   @default(now())
  incidents Incident[] @relation("IncidentCreator")
}

enum IncidentType {
  VIOLENCE
  RESTRICTED_ZONE
  ABNORMAL
  MANUAL
}

enum IncidentStatus {
  OPEN
  RESOLVED
}

model Incident {
  id          Int            @id @default(autoincrement())
  type        IncidentType
  status      IncidentStatus @default(OPEN)
  description String?
  source      String         @default("manual")
  createdAt   DateTime       @default(now())
  resolvedAt  DateTime?
  createdById Int?
  createdBy   User?          @relation("IncidentCreator", fields: [createdById], references: [id], onDelete: SetNull)
}
